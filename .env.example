# Copy to .env.local and fill in values.

# --- Supabase (required for API routes) ---
# Project URL: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# anon key (optional for this app; server uses service role)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# service_role secret — never expose to the browser
SUPABASE_SERVICE_KEY=your-service-role-key

# --- Serper (required for scraping) ---
# https://serper.dev
SERPER_API_KEY=your_serper_api_key

# --- Resend (required for emails) ---
# https://resend.com
RESEND_API_KEY=re_xxxxxxxx
# Verified domain or onboarding@resend.dev for testing (limited recipients)
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_FROM_NAME=AutoFlow
# Optional: replies go here
REPLY_TO_EMAIL=you@yourdomain.com
